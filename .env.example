# ── Notary agent (packages/agent) ────────────────────────────────────────────
# The testnet2 gateway key is PUBLIC — published in the Sphere SDK README and
# safe to commit. A MAINNET key would be a real secret; never put one here.
UNICITY_API_KEY=sk_ddc3cfcc001e4a28ac3fad7407f99590

# Identity persistence (critical): the wallet lives in DATA_DIR. Alternatively
# pin a fixed mnemonic so any fresh machine boots the same identity.
DATA_DIR=./wallet-data
DB_PATH=./notary.db
# WALLET_MNEMONIC="twelve words ..."
NOTARY_NAMETAG=notary

# Fees (basis points)
FEE_BPS=100
DISPUTE_FEE_BPS=50

# Arbitration — disputes open an evidence window, then an AI arbiter rules a
# split. Set ANTHROPIC_API_KEY to enable the Claude judge; without it, disputes
# fall back to a deterministic rule (full refund if the seller showed no
# evidence, else 50/50). ANTHROPIC_API_KEY is a real secret — never commit one.
# ANTHROPIC_API_KEY=sk-ant-...
ARBITER_MODEL=claude-opus-4-8
DISPUTE_WINDOW_MS=86400000

# Escrow limits (base units; UCT has 18 decimals, so 1 UCT = 1e18)
MIN_ESCROW=1
MAX_ESCROW=1000000000000000000000000
# ALLOWED_COINS=UCT

# Timers (ms unless noted)
ACCEPT_TIMEOUT_MS=3600000
FUNDING_TIMEOUT_MS=86400000
DEFAULT_DELIVERY_HOURS=72
CONFIRM_TIMEOUT_MS=172800000
TIMER_POLL_MS=15000

# Treasury (base units; 1 UCT = 1e18)
TREASURY_FLOOR=1000000000000000000
TREASURY_MINT_AMOUNT=10000000000000000000
TREASURY_THRESHOLD=100000000000000000000
PREFERRED_COIN=UCT
TREASURY_POLL_MS=300000
TREASURY_AUTO_SWAP=false

# Discovery / API
INTENT_REFRESH_MS=21600000
API_PORT=8787
API_HOST=0.0.0.0
DOCS_URL=https://github.com/CodeWithShamim/Notary

# Ops
LOG_LEVEL=info
POOL_DEADLINE_MS=86400000

# ── Web app (packages/web) — Vite reads VITE_* ───────────────────────────────
VITE_UNICITY_API_KEY=sk_ddc3cfcc001e4a28ac3fad7407f99590
VITE_NOTARY_TAG=notary
VITE_AGENT_API=http://localhost:8787
# Sphere Connect popup-fallback wallet (iframe/extension are auto-detected first).
VITE_SPHERE_WALLET_URL=https://sphere.unicity.network
